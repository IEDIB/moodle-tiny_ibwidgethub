{
    "key": "ib-button",
    "name": "Hipervincle com a botó",
    "category": "bootstrap",
    "icon": "fa fa-hand-pointer",
    "instructions": "Mostra un hipervincle amb format botó de Bootstrap.",
    "template": "<a href=\"{{url}}\" class=\"btn btn-{{severity}}\"{{#blank}} target=\"_blank\"{{/blank}} role=\"button\"><i class=\"fa fa-{{icon}}\" aria-hidden=\"true\"></i> Lorem ipsum</a> \n",
    "selectors": "a.btn",
    "parameters": [
        {
            "name": "url",
            "title": "URL de l'enllaç",
            "bind": "attr('href')",
            "value": "#"
        },
        {
            "name": "blank",
            "title": "Obrir en nova finestra",
            "value": false,
            "bind": "hasAttr('target=_blank')"
        },
        {
            "name": "severity",
            "title": "Estil del botó",
            "bind": "classRegex('btn-(.*)')",
            "value": "outline-info",
            "options": [
                "primary",
                "secondary",
                "success",
                "info",
                "warning",
                "danger",
                "light",
                "dark",
                "outline-primary",
                "outline-secondary",
                "outline-success",
                "outline-info",
                "outline-warning",
                "outline-danger",
                "outline-light",
                "outline-dark"
            ]
        },
        {
            "name": "icon",
            "title": "Icona del botó",
            "tip": "fa fa-*",
            "bind": "classRegex('fa-(.*)', 'i')",
            "value": "tag"
        }
    ],
    "author": "Josep Mulet <pep.mulet@gmail.com>",
    "version": "1.2.0"
}