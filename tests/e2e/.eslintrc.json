{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2021": true,
    "cypress": true,
    "cypress/globals": false
  },
  "extends": [
    "eslint:recommended",
    "plugin:cypress/recommended" // optional, if using Cypress plugin
  ],
  "plugins": ["cypress"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "types": ["node", "cypress"]
}
